<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Sensible default: pull Spring Boot's standard color/console patterns
         for everything except prod, where we emit JSON via logstash-encoder. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.chipIn.ChipIn" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Stable, parseable field names. -->
                <includeContext>false</includeContext>
                <includeMdc>true</includeMdc>
                <customFields>{"service":"chipin-service"}</customFields>
                <fieldNames>
                    <timestamp>ts</timestamp>
                    <message>msg</message>
                    <level>level</level>
                    <thread>thread</thread>
                    <logger>logger</logger>
                    <stackTrace>stack</stackTrace>
                </fieldNames>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="com.chipIn.ChipIn" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>
</configuration>
